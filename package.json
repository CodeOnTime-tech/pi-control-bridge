{
  "name": "pi-control-bridge",
  "version": "0.3.5",
  "description": "Pi agent bridge extension and singleton runtime for pi-control-hub integration.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "bridge",
    "control-hub"
  ],
  "license": "MIT",
  "type": "module",
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "hono": "^4.7.4"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "esbuild": "^0.25.1",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "bin": {
    "pi-bridge": "./dist/bridge/main.js"
  },
  "files": [
    "dist/bridge/main.js",
    "extension/",
    "shared/",
    "bridge.config.example.json",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./extension/index.ts"
    ]
  },
  "scripts": {
    "build": "esbuild bridge/main.ts --bundle --platform=node --format=esm --outfile=dist/bridge/main.js --banner:js=\"#!/usr/bin/env node\"",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "check": "tsc --noEmit"
  }
}
